# Public client env (VITE_ = inlined vào bundle → an toàn để commit vào .env).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- KHÔNG đặt các key dưới đây vào .env (đã tracked) ---
# Service-role key (bypass RLS) và các secret khác → đặt trong .dev.vars HOẶC .env.local
# (đã gitignore). Phase 02 seed + Phase 04 Edge Function đọc từ đó.
#   SUPABASE_SERVICE_ROLE_KEY=   (trong .dev.vars)
#   ANTHROPIC_API_KEY=           (trong .dev.vars / function secret)
