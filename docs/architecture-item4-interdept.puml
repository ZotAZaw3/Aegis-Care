@startuml item4_interdept_coordination
title Aegis Care — Inter-Department Coordination Architecture (Đề bài mục 4)
skinparam componentStyle rectangle
skinparam wrapWidth 200
skinparam defaultTextAlignment center

actor "Receptionist" as Recep
actor "Dentist" as Dentist
actor "Lab Technician" as LabTech
actor "Assistant\n(Imaging)" as Assist
actor "Admin" as Admin

package "Frontend — per-station queues (React + TanStack Query)" {
  [/reception\nReceptionBoard + ConsentQueue\n+ OrderExecutionList] as UI_Reception
  [/clinic\nOpenCasesBoard + PendingReviewQueue] as UI_Clinic
  [/lab\nLabBoard] as UI_Lab
  [/execution\nOrderExecutionList] as UI_Exec
  [/follow-ups\nRecallQueue] as UI_Recall
}

package "Supabase (per-request JWT client, RLS enforced)" {
  database "Postgres" as PG {
    [departments\n(reception|treatment|imaging|lab|pharmacy)] as T_Dept
    [staff_departments\n(staff ↔ dept, n-n)] as T_StaffDept
    [medical_orders\n(department_id, status, assigned_role)] as T_Orders
    [order_evidence\n(append-only proof of close)] as T_Evidence
    [visit_sessions\n(walk-in queue)] as T_Visits
  }

  component "route_order()\nBEFORE INSERT trigger\n→ status open→routed\n→ department_id = dept_id_for_order_type(order_type)\n  hoặc kb_rules.department_id" as Trg_Route
  component "is_in_department()\nSECURITY DEFINER" as Fn_InDept
  component "RLS policy\n\"dept insert evidence\"\n(chỉ staff đúng phòng,\nhoặc dentist/admin override)" as RLS_Evidence
  component "get_my_departments()\n→ phòng caller đang trực" as Fn_MyDept
  component "Realtime\npostgres_changes\n(medical_orders, order_evidence)" as Realtime
}

Recep --> UI_Reception
Dentist --> UI_Clinic
LabTech --> UI_Lab
Assist --> UI_Reception
Admin --> UI_Exec

UI_Reception --> Fn_MyDept
UI_Clinic --> Fn_MyDept
UI_Lab --> Fn_MyDept
UI_Exec --> Fn_MyDept
Fn_MyDept --> T_StaffDept

T_Orders --> Trg_Route : INSERT (mọi nguồn:\nKB draft / custom / consent con / recall)
Trg_Route --> T_Dept : tra department_id

UI_Reception --> T_Orders : SELECT ...in(department_id)
UI_Clinic --> T_Orders
UI_Lab --> T_Orders
UI_Exec --> T_Orders

UI_Reception --> T_Evidence : INSERT evidence (đóng lệnh)
UI_Clinic --> T_Evidence
UI_Lab --> T_Evidence
T_Evidence --> RLS_Evidence : WITH CHECK
RLS_Evidence --> Fn_InDept : is_in_department(auth.uid(), order.department_id)
Fn_InDept --> T_StaffDept

T_Orders --> Realtime
T_Evidence --> Realtime
Realtime ..> UI_Reception : invalidate\n(order chuyển sang\nphòng kế tiếp hiện ngay)
Realtime ..> UI_Clinic
Realtime ..> UI_Lab
Realtime ..> UI_Exec
Realtime ..> UI_Recall

note right of RLS_Evidence
  Chặn đóng lệnh SAI phòng ở tầng
  RLS (deterministic, DB-enforced) —
  không phải quy ước UI có thể lách.
  dentist/admin override để giữ
  human-first.
end note

note right of Trg_Route
  1 y lệnh luôn có ĐÚNG 1 department_id
  → không "thất lạc" khi đi qua
  Reception → Treatment → Imaging/Lab
  → Pharmacy. Handoff = đổi department_id,
  không phải nhắn tin thủ công.
end note

@enduml
