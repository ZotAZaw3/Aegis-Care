@startuml aegis_care_pitch_architecture
title Aegis Care — Architecture
skinparam wrapWidth 220
skinparam defaultTextAlignment center
skinparam roundcorner 12
skinparam shadowing false
skinparam packageStyle rectangle
skinparam backgroundColor transparent

skinparam rectangle {
  BackgroundColor<<human>> #2d6a4f
  FontColor<<human>> white
  BackgroundColor<<agent>> #1d3557
  FontColor<<agent>> white
  BackgroundColor<<orchestrator>> #14213d
  FontColor<<orchestrator>> white
  BackgroundColor<<tool>> #457b9d
  FontColor<<tool>> white
  BackgroundColor<<engine>> #457b9d
  FontColor<<engine>> white
  BackgroundColor<<pillar>> #a8dadc
  FontColor<<pillar>> #1d1d1d
}

rectangle "👩‍⚕️ Clinician\nquyết định lâm sàng cuối cùng" <<human>> as Human

package "🤖 AI Agent — 1 lệnh gọi generateText(),\nvòng lặp tool tối đa 5-12 bước (stopWhen)" <<agent>> {
  rectangle "🎼 Orchestrator\ngpt-4o-mini, temperature=0\nSystem prompt: retrieval-only,\nchặn chẩn đoán/khuyến nghị" <<orchestrator>> as Orchestrator

  rectangle "🔎 kb_search\n(RAG luật/SOP)" <<tool>> as T1
  rectangle "🧬 patient_history\nsafety_panel · crm_recall\npatient_labs · find_patient" <<tool>> as T2
  rectangle "⚠️ open_violations\norder_drafts" <<tool>> as T3

  Orchestrator -right-> T1
  Orchestrator -down-> T2
  Orchestrator -left-> T3
  T1 -up-> Orchestrator : chunk + citation
  T2 -up-> Orchestrator : fact + citation
  T3 -up-> Orchestrator : list + citation
}

rectangle "⚙️ Deterministic Engine\nCompliance Judge · Violation Counter · Order Router\n100% SQL/trigger — KHÔNG LLM phán compliance" <<engine>> as Engine

rectangle "📘 Compliance\nKnowledge Base" <<pillar>> as KB
rectangle "🧬 Customer Graph\n(EMR)" <<pillar>> as EMR
rectangle "📋 Order-Centric Core" <<pillar>> as Orders

Human <-down-> Orchestrator : hỏi & nhận câu trả lời\nCÓ TRÍCH DẪN
T1 -down-> KB
T2 -down-> EMR
T3 -down-> Orders
Engine -up-> Orders
Engine -up-> KB

note right of Human
  **Human-first, Agent-support.**
  Mỗi tool trả FACT + citation —
  Orchestrator chỉ NARRATE,
  không tự suy diễn giữa các bước.
end note

note bottom of Engine
  Compliance Judge/Violation Counter
  chạy SONG SONG, độc lập với Agent —
  không phải Agent "tính" compliance.
end note

@enduml
